---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:root {
				--bg-color: #0b0f19;
				--text-color: #f1f5f9;
				--accent: #3b82f6;
				--accent-gradient: linear-gradient(135deg, #3b82f6, #8b5cf6, #ec4899);
				--glass-bg: rgba(255, 255, 255, 0.05);
				--glass-border: rgba(255, 255, 255, 0.1);
			}
			
			body {
				background-color: var(--bg-color);
				color: var(--text-color);
				font-family: 'Inter', 'Atkinson', sans-serif;
				margin: 0;
				padding: 0;
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				overflow-x: hidden;
			}

			.hero-section {
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				min-height: 80vh;
				text-align: center;
				padding: 2rem;
				position: relative;
			}

			.hero-section::before {
				content: '';
				position: absolute;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				width: 600px;
				height: 600px;
				background: var(--accent-gradient);
				filter: blur(150px);
				opacity: 0.15;
				z-index: -1;
				border-radius: 50%;
				animation: pulse 8s ease-in-out infinite;
			}

			@keyframes pulse {
				0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.15; }
				50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.25; }
			}

			h1 {
				font-size: 4rem;
				font-weight: 800;
				margin-bottom: 1rem;
				letter-spacing: -0.05em;
				line-height: 1.1;
			}

			.text-gradient {
				background-image: var(--accent-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-size: 400%;
				background-position: 0%;
				animation: gradientMove 5s ease infinite;
			}

			@keyframes gradientMove {
				0% { background-position: 0% 50%; }
				50% { background-position: 100% 50%; }
				100% { background-position: 0% 50%; }
			}

			.subtitle {
				font-size: 1.25rem;
				color: #94a3b8;
				max-width: 600px;
				margin: 0 auto 2rem auto;
				line-height: 1.6;
			}

			.links-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.5rem;
				width: 100%;
				max-width: 900px;
				margin: 3rem auto;
				padding: 0 1rem;
			}

			.glass-card {
				background: var(--glass-bg);
				border: 1px solid var(--glass-border);
				border-radius: 1rem;
				padding: 2rem;
				text-decoration: none;
				color: inherit;
				backdrop-filter: blur(10px);
				transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
				position: relative;
				overflow: hidden;
				display: flex;
				flex-direction: column;
				align-items: flex-start;
			}

			.glass-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: -100%;
				width: 50%;
				height: 100%;
				background: linear-gradient(
					to right,
					transparent,
					rgba(255, 255, 255, 0.05),
					transparent
				);
				transform: skewX(-20deg);
				transition: all 0.5s ease;
			}

			.glass-card:hover {
				transform: translateY(-5px);
				border-color: rgba(255, 255, 255, 0.2);
				box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
			}

			.glass-card:hover::before {
				left: 200%;
			}

			.glass-card h2 {
				font-size: 1.5rem;
				margin: 0 0 0.5rem 0;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.glass-card p {
				color: #94a3b8;
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.5;
			}
			
			.glass-card span {
				margin-top: 1rem;
				font-size: 0.875rem;
				color: var(--accent);
				font-weight: 600;
				display: inline-flex;
				align-items: center;
				transition: transform 0.2s ease;
			}
			
			.glass-card:hover span {
				transform: translateX(5px);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-section">
				<h1>Hi, I'm <span class="text-gradient">istino</span></h1>
				<p class="subtitle">
					Digital creator, developer, and lifelong learner. Exploring the intersection of technology, design, and personal growth.
				</p>
				
				<div class="links-grid">
					<a href="/about" class="glass-card">
						<h2>Profile & Docs <span>&rarr;</span></h2>
						<p>Explore my personal journey, skills, and living documentation.</p>
					</a>
					<a href="/blog" class="glass-card">
						<h2>Tech Blog <span>&rarr;</span></h2>
						<p>Read my latest thoughts on software engineering and life.</p>
					</a>
					<a href="https://github.com/istino" target="_blank" class="glass-card">
						<h2>Projects <span>&rarr;</span></h2>
						<p>Check out what I'm building on GitHub.</p>
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
